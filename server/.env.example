PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/vibe_db

# Cloudinary (이미지 업로드)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 허용할 클라이언트 도메인 (여러 개면 쉼표로 구분)
# 예: https://your-app.vercel.app,https://www.your-domain.com
CORS_ORIGIN=http://localhost:5173
